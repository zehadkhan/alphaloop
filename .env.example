# ============================================================
# AlphaLoop — Environment Variables Template
# Copy to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── API Keys ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CMC_API_KEY=...
OPENROUTER_API_KEY=

# CMC Agent Hub (leave blank to use standard Pro API)
CMC_AGENT_HUB_URL=
# x402 payment recipient (CMC Agent Hub payment channel address)
X402_RECIPIENT=
X402_ENABLED=false

# ── Database ────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./storage/alphaloop.db

# ── Wallet ──────────────────────────────────────────────────
AGENT_PRIVATE_KEY=0x...
AGENT_WALLET_ADDRESS=0x...
WALLET_PASSWORD=change-me-to-something-strong

# ── Network ─────────────────────────────────────────────────
# Development / testnet (default)
ENVIRONMENT=testnet
BSC_RPC_URL=https://bsc-testnet-rpc.publicnode.com

# Live trading — uncomment for Jun 22–28 window
# ENVIRONMENT=mainnet
# BSC_RPC_URL=https://bsc-dataseed.binance.org/

# ── Trading ─────────────────────────────────────────────────
DRY_RUN=true
TRADING_PAIR=BNB/USDT
MAX_POSITION_SIZE_USD=10
MIN_CONFIDENCE=0.6
CYCLE_INTERVAL_MINUTES=30
MAX_DAILY_LOSS_USD=50
STOP_LOSS_PERCENT=5

# ── TWAK (Trust Wallet Agent Kit) ───────────────────────────
# Install: curl -fsSL https://agent-kit.trustwallet.com/install.sh | bash
# Credentials from: https://portal.trustwallet.com
# Then:
#   twak wallet import --name alphaloop
#   twak serve   (starts REST server, default port 7777)
TWAK_REST_URL=http://localhost:7777
TWAK_WALLET_NAME=alphaloop
TWAK_HMAC_SECRET=<from portal.trustwallet.com>

# ── Competition Guards ───────────────────────────────────────
COMPETITION_MODE=false
# Set INITIAL_PORTFOLIO_USD to your exact starting balance on Jun 22
INITIAL_PORTFOLIO_USD=1000
MAX_DRAWDOWN_PCT=25
MAX_POSITION_HOLD_HOURS=20

# ── Token Scanner ─────────────────────────────────────────────
TOKEN_SCAN_TOP_N=3

# ── ERC-8004 Agent Registration (BNB Agent SDK) ──────────────
# Public URL of your deployed agent endpoint
AGENT_PUBLIC_URL=https://your-agent-url/erc8183
